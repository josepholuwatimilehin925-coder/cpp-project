{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C File",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/gcc.exe",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-mconsole",
                "-fdiagnostics-color=always"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile C source file"
        },
        {
            "label": "Build C++ File",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-mconsole",
                "-fdiagnostics-color=always"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Compile C++ source file"
        }
    ]
}